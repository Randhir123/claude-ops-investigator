{
  "permissions": {
    "allow": [
      "mcp__claude-ops-investigator__k8s_get_pod_logs",
      "mcp__claude-ops-investigator__evidence_get_detail",
      "mcp__claude-ops-investigator__k8s_describe_pod",
      "mcp__claude-ops-investigator__runbook_search",
      "mcp__claude-ops-investigator__k8s_get_recent_namespace_events",
      "mcp__claude-ops-investigator__k8s_list_pods",
      "mcp__claude-ops-investigator__k8s_top_pods"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/block_unsafe_shell.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__claude-ops-investigator__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/audit_mcp_tool_call.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/audit_subagent_lifecycle.py\" SubagentStart",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/audit_subagent_lifecycle.py\" SubagentStop",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate_final_report.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
