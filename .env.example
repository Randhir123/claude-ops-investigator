# Copy this file to .env and fill in real values locally.
# .env is gitignored — never commit real credentials.

PROMETHEUS_URL=http://localhost:9090
PROMETHEUS_AUTO_PORT_FORWARD=false
PROMETHEUS_PF_SERVICE=kube-prometheus-stack-prometheus
PROMETHEUS_PF_NAMESPACE=monitoring
PROMETHEUS_PF_LOCAL_PORT=9090
PROMETHEUS_PF_REMOTE_PORT=9090

IBM_LOGS_ENDPOINT=https://<guid>.api.<region>.logs.cloud.ibm.com
IBM_CLOUD_API_KEY=<do-not-commit-real-key>
